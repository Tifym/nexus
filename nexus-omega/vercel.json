{
  "version": 2,
  "routes": [
    { "src": "/styles.css", "dest": "/public/styles.css" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/sounds/(.*)", "dest": "/public/sounds/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/api/index" }
  ],
  "crons": [
    { "path": "/api/evaluate", "schedule": "0 0 * * *" }
  ]
}
